    {
      "parameters": {
        "jsCode": "const db = $json;\nconst fixture = $('Fixture aufbereiten1').item.json;\n\nconst phaseChanged = fixture.new_phase !== db.match_phase;\n\nreturn [{\n  json: {\n    match_id: db.id,\n    fixture_id: fixture.fixture_id,\n    new_minute: fixture.new_minute,\n    new_minute_extra: fixture.new_minute_extra,\n    new_phase: fixture.new_phase,\n    new_state: fixture.new_state ?? db.match_state,\n    status_short: fixture.status_short,\n    old_phase: db.match_phase,\n    match_state: db.match_state,\n    ticker_mode: db.ticker_mode ?? 'coop',\n    phase_changed: phaseChanged,\n  }\n}];"
      },
