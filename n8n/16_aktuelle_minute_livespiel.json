      "parameters": {
        "jsCode": "const fixture = $json.response?.[0];\nif (!fixture) return [];\n\nconst phaseMap = {\n  '1H': 'FirstHalf',\n  'HT': 'FirstHalfBreak',\n  '2H': 'SecondHalf',\n  'ET': 'ExtraFirstHalf',\n  'BT': 'ExtraBreak',\n  'P':  'PenaltyShootout',\n  'FT': 'FullTime',\n  'AET': 'ExtraSecondHalf',\n  'PEN': 'PenaltyShootout',\n};\n\nconst stateMap = {\n  '1H': 'Live', 'HT': 'Live', '2H': 'Live',\n  'ET': 'Live', 'BT': 'Live', 'P': 'Live',\n  'FT': 'FullTime', 'AET': 'FullTime', 'PEN': 'FullTime',\n};\n\nconst statusShort = fixture.fixture.status.short;\nconst newPhase = phaseMap[statusShort];\nif (!newPhase) return []; // NS, TBD, CANC etc. — nichts tun\n\nreturn [{\n  json: {\n    fixture_id: fixture.fixture.id,\n    status_short: statusShort,\n    new_minute: fixture.fixture.status.elapsed ?? null,\n    new_minute_extra: fixture.fixture.status.extra ?? null,\n    new_phase: newPhase,\n    new_state: stateMap[statusShort] ?? null,\n  }\n}];"
      },
