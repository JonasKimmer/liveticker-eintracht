    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const data = item.json;\n\n  const link = data.link ?? data.url ?? '';\n  \n  const vidMatch = link.match(/status\\/(\\d+)/);\n  const vid = vidMatch ? vidMatch[1] : null;\n\n  const content = data.content ?? data['content:encoded'] ?? '';\n  const imgMatch = content.match(/src=\"(https:\\/\\/pbs\\.twimg\\.com\\/[^\"]+)\"/);\n  const thumbnail_url = imgMatch ? imgMatch[1] : null;\n\n  return {\n    json: {\n      vid: vid ?? data.guid ?? link,\n      title: data.title ?? data.contentSnippet ?? '',\n      video_url: link,\n      thumbnail_url,\n    }\n  };\n}).filter(item => item.json.vid);"
      },
      "id": "ca7a24ec-f3ce-44aa-9918-ab9d647c1173",
      "name": "Extract Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
