        "query": "INSERT INTO media_clips (vid, title, video_url, thumbnail_url, source, team_name, published)\nVALUES ($1, $2, $3, $4, 'instagram', 'Eintracht Frankfurt', false)\nON CONFLICT (vid) WHERE vid IS NOT NULL DO UPDATE SET\n  title         = EXCLUDED.title,\n  video_url     = EXCLUDED.video_url,\n  thumbnail_url = EXCLUDED.thumbnail_url\nRETURNING vid, thumbnail_url;",
