    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const data = item.json;\n\n  const link = data.link ?? data.url ?? '';\n  const vidMatch = link.match(/\\/p\\/([A-Za-z0-9_-]+)/);\n  const vid = vidMatch ? vidMatch[1] : null;\n\n  const content = data.content ?? data['content:encoded'] ?? '';\n  // Bild-Post: <img src=\"...\">  /  Video-Post (Reel): <video poster=\"...\">\n  const imgMatch = content.match(/src=\"([^\"]+)\"/) ?? content.match(/poster=\"([^\"]+)\"/);\n  const thumbnail_url = imgMatch ? imgMatch[1] : null;\n\n  return {\n    json: {\n      vid: vid ?? link,\n      title: data.title ?? '',\n      video_url: link,\n      thumbnail_url: thumbnail_url ?? null,\n    }\n  };\n}).filter(item => item.json.vid);"
      },
