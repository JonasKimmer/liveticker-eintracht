    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.flatMap(item => {\n  if (!item.json.response) return [];\n  const fixtureId = item.json.parameters?.fixture;\n\n  return item.json.response.map(event => ({\n    json: {\n      fixture_id:       fixtureId,\n      minute:           event.time.elapsed,\n      extra_time:       event.time.extra || null,\n      team_external_id: event.team.id,\n      team_name:        event.team?.name || null,\n      player_id:        event.player?.id || null,\n      player_name:      event.player?.name || null,\n      assist_id:        event.assist?.id || null,\n      assist_name:      event.assist?.name || null,\n      type:             event.type,\n      detail:           event.detail,\n      comments:         event.comments || null\n    }\n  }));\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        336,
        688
      ],
      "id": "6fcf67aa-622f-4dcb-bb84-15aac8dd88d9",
      "name": "Events extrahieren2"
    },
    {
      "parameters": {
        "jsCode": "const TYPE_MAP = {\n  'Goal':  'goal',\n  'Card':  'yellow_card',\n  'subst': 'substitution',\n  'Var':   'comment',\n  'Miss':  'missed_penalty',\n};\n\nfunction normalizeType(type, detail) {\n  if (type === 'Card') {\n    const d = (detail || '').toLowerCase();\n    if (d.includes('red')) return 'red_card';\n    return 'yellow_card';\n  }\n  if (type === 'Goal') {\n    const d = (detail || '').toLowerCase();\n    if (d.includes('own')) return 'own_goal';\n    return 'goal';\n  }\n  return TYPE_MAP[type] || 'comment';\n}\n\nfunction esc(val) {\n  if (val === null || val === undefined) return 'NULL';\n  return `'${String(val).replace(/'/g, \"''\")}'`;\n}\n\nfunction num(val) {\n  return (val === null || val === undefined) ? 'NULL' : val;\n}\n\nreturn $input.all().map(item => {\n  const e = item.json;\n  const eventType = normalizeType(e.type, e.detail);\n  const sourceId = `apifootball_${e.fixture_id}_${e.minute}_${e.type}_${e.player_id ?? 'x'}`;\n  const description = JSON.stringify({\n    player_id:   e.player_id,\n    player_name: e.player_name,\n    assist_id:   e.assist_id,\n    assist_name: e.assist_name,\n    team_id:     e.team_external_id,\n    team_name:   e.team_name,\n    type:        e.type,\n    detail:      e.detail,\n    comments:    e.comments,\n  });\n  const query = `\n    INSERT INTO events (\n      match_id, time, time_additional,\n      event_type, description, source, source_id, position\n    )\n    VALUES (\n      (SELECT id FROM matches WHERE external_id = ${num(e.fixture_id)}::integer),\n      ${num(e.minute)},\n      ${num(e.extra_time)},\n      ${esc(eventType)},\n      ${esc(description)},\n      'api_football',\n      ${esc(sourceId)},\n      ${num(e.minute)}\n    )\n    ON CONFLICT (source_id) WHERE source_id IS NOT NULL\n    DO NOTHING\n    RETURNING id, event_type, time, description\n  `.trim();\n  return { json: { query, fixture_id: e.fixture_id } };\n});"
      },
