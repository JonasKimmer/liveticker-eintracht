    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH match_teams AS (\n  SELECT m.id, m.home_team_id, m.away_team_id,\n    ht.external_id AS home_ext,\n    at.external_id AS away_ext\n  FROM matches m\n  JOIN teams ht ON ht.id = m.home_team_id\n  JOIN teams at ON at.id = m.away_team_id\n  WHERE m.id = $1\n),\nscores AS (\n  SELECT\n    COALESCE(SUM(CASE\n      WHEN (e.event_type = 'goal' OR e.event_type = 'own_goal')\n           AND (e.description::jsonb->>'team_id')::integer = mt.home_ext THEN 1\n      ELSE 0 END), 0) AS home_score,\n    COALESCE(SUM(CASE\n      WHEN (e.event_type = 'goal' OR e.event_type = 'own_goal')\n           AND (e.description::jsonb->>'team_id')::integer = mt.away_ext THEN 1\n      ELSE 0 END), 0) AS away_score\n  FROM events e, match_teams mt\n  WHERE e.match_id = mt.id\n    AND e.event_type IN ('goal', 'own_goal')\n)\nUPDATE matches SET\n  home_score = (SELECT home_score FROM scores),\n  away_score = (SELECT away_score FROM scores)\nWHERE id = $1\nRETURNING id, home_score, away_score",
        "options": {
          "queryReplacement": "={{ [$('DB: Match-Instanz1').first().json.match_id] }}"
