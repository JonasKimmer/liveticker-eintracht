    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  m.id AS match_id,\n  COALESCE($2, m.ticker_mode) AS ticker_mode,\n  CASE WHEN (ht.name ILIKE '%Frankfurt%' OR at.name ILIKE '%Frankfurt%')\n       THEN 'ef_whitelabel' ELSE 'generic' END AS instance,\n  CASE WHEN (ht.name ILIKE '%Frankfurt%' OR at.name ILIKE '%Frankfurt%')\n       THEN 'euphorisch' ELSE 'neutral' END AS style,\n  CASE WHEN ht.name ILIKE '%Frankfurt%' THEN ht.name\n       WHEN at.name ILIKE '%Frankfurt%' THEN at.name\n       ELSE NULL END AS fan_team\nFROM matches m\nJOIN teams ht ON ht.id = m.home_team_id\nJOIN teams at ON at.id = m.away_team_id\nWHERE m.external_id = $1\nLIMIT 1\n",
        "options": {
          "queryReplacement": "={{ $json.body.fixture_id + ',' + ($json.body.ticker_mode ?? '') }}"
        }
      },
