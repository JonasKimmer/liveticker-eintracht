    {
      "parameters": {
        "jsCode": "const players = $input.first().json?.result?.data?.squad?.data?.players;\n\nif (!players?.length) {\n  throw new Error('Keine Spieler gefunden');\n}\n\nreturn players.map(p => {\n  const id = p.person?.id;\n  const lastName = p.person?.last_name;\n  const firstName = p.person?.first_name;\n  const jerseyNumber = p.person?.jersey_number;\n  const slug = p.person?.slug;\n\n  if (!id) return null;\n\n  // ID → S3-Pfad: '492931' → '000/492/931'\n  const padded = id.padStart(9, '0');\n  const s3path = `${padded.slice(0,3)}/${padded.slice(3,6)}/${padded.slice(6,9)}`;\n\n  // Avatar: Originalname mit Umlaut, URL-encoded (Götze → G%C3%B6tze)\n  const avatarName = encodeURIComponent(lastName.split(/[\\s-]/)[0]);\n\n  // Video: Normalisierter Name ohne Umlaut (Götze → Gotze, Chaïbi → Chaibi)\n  const videoName = lastName\n    .normalize('NFD')\n    .replace(/[\\u0300-\\u036f]/g, '')\n    .split(/[\\s-]/)[0];\n\n  const avatarUrl = `https://liveticker-eintracht-de.s3.eu-central-1.amazonaws.com/people/liveticker_avatars/${s3path}/large/${avatarName}.png`;\n\n  const videoUrl = jerseyNumber\n    ? `https://liveticker-eintracht-de.s3.eu-central-1.amazonaws.com/people/liveticker_videos/${s3path}/original/Torschuetze_${String(jerseyNumber).padStart(2, '0')}_${videoName}_HD_1.mp4`\n    : null;\n\n  return {\n    json: {\n      id,\n      slug,\n      first_name: firstName,\n      last_name: lastName,\n      jersey_number: jerseyNumber,\n      position: p.person?.position,\n      avatar_url: avatarUrl,\n      video_url: videoUrl\n    }\n  };\n}).filter(Boolean);"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        256,
        0
      ],
      "id": "59e074bb-8bf9-4b29-bc99-9dbe7c807cf0",
      "name": "Spieler + URLs extrahieren"
    },
    {
      "parameters": {
        "jsCode": "// Für jeden Spieler: SQL-Upsert generieren\n// Matched über last_name + jersey_number (kein external_id von EF-Website)\nfunction esc(val) {\n  if (val === null || val === undefined) return 'NULL';\n  return `'${String(val).replace(/'/g, \"''\")}'`;\n}\nfunction num(val) {\n  return (val === null || val === undefined) ? 'NULL' : val;\n}\n\nreturn $input.all().map(item => {\n  const p = item.json;\n  const query = `\n    UPDATE players\n    SET\n      image_url  = ${esc(p.avatar_url)},\n      video_url  = ${esc(p.video_url)},\n      updated_at = NOW()\n    WHERE\n      jersey_number = ${num(p.jersey_number)}\n      AND team_id IN (\n        SELECT id FROM teams WHERE name ILIKE '%Frankfurt%'\n      )\n    RETURNING id, display_name, jersey_number, video_url\n  `.trim();\n  return { json: { query, player: p.last_name } };\n});"
      },
