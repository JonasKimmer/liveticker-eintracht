    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO media_clips (vid, video_url, thumbnail_url, title, source, published)\nVALUES (\n  '{{ $json.vid }}',\n  '{{ $json.url }}',\n  '{{ $json.thumbnail }}',\n  '{{ $json.titel.replace(/'/g, \"''\") }}',\n  'youtube',\n  false\n)\nON CONFLICT (vid) WHERE vid IS NOT NULL DO UPDATE SET\n  title = EXCLUDED.title,\n  thumbnail_url = EXCLUDED.thumbnail_url",
