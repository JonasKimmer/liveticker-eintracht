    {
      "parameters": {
        "jsCode": "const results = [];\nfor (const item of $input.all()) {\n  const markdown = item.json.data.markdown || '';\n  const videoRegex = /### \\[(.*?)\\]\\((https:\\/\\/www\\.youtube\\.com\\/watch\\?v=[^\\s)]+)/g;\n  let match;\n  while ((match = videoRegex.exec(markdown)) !== null) {\n    const url = match[2];\n    // Regex statt new URL() — URL-Klasse nicht im n8n Sandbox verfügbar\n    const vidMatch = url.match(/[?&]v=([A-Za-z0-9_-]{11})/);\n    const vid = vidMatch ? vidMatch[1] : null;\n    results.push({\n      json: {\n        titel: match[1],\n        url: url,\n        vid: vid,\n        thumbnail: vid ? `https://img.youtube.com/vi/${vid}/mqdefault.jpg` : null\n      }\n    });\n  }\n}\nif (results.length === 0) {\n  return [{ json: { error: 'Keine Videos gefunden.' } }];\n}\nreturn results;\n"
      },
