    {
      "parameters": {
        "jsCode": "const teamId = $('Variablen setzen4').first().json.teamId;\nconst season = $('Variablen setzen4').first().json.season;\nreturn $input.first().json.response.map(item => ({\n  json: {\n    league_id: item.league.id,\n    league_name: item.league.name,\n    league_logo: item.league.logo,\n    season,\n    teamId\n  }\n}));"
