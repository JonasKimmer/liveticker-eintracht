          "name": "Postgres account 2"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH s AS (\n  INSERT INTO seasons (external_id, sport, title)\n  VALUES ($1, 'football', $4)\n  ON CONFLICT (external_id) DO UPDATE SET title = EXCLUDED.title\n  RETURNING id\n)\nINSERT INTO competition_teams (uid, season_id, competition_id, team_id, created_at)\nVALUES (\n  gen_random_uuid(),\n  (SELECT id FROM s),\n  (SELECT id FROM competitions WHERE external_id = $2),\n  (SELECT id FROM teams WHERE external_id = $3),\n  now()\n)\nON CONFLICT (season_id, competition_id, team_id) DO NOTHING",
        "options": {
          "queryReplacement": "={{ [2025, $json.league_id, $json.teamId, '2024/2025'] }}"
        }
      },
      "id": "08e2bb6f-ba8a-4d3c-a5c9-18e8d37985ff",
