    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO competitions (uid, external_id, sport, title, logo_url, hidden, position)\nVALUES (gen_random_uuid(), $1, 'football', $2, $3, false, 1)\nON CONFLICT (external_id) DO UPDATE SET\n  title    = EXCLUDED.title,\n  logo_url = EXCLUDED.logo_url",
        "options": {
          "queryReplacement": "={{ [$json.league_id, $json.league_name, $json.league_logo || null] }}"
        }
      },
      "id": "eb05357e-52ef-4d49-856c-00b798447884",
      "name": "UPSERT Competitions",
      "type": "n8n-nodes-base.postgres",
