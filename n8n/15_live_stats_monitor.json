    {
      "parameters": {
        "jsCode": "// --- Eingaben ---\nconst stats = $('Get Statistics2').item.json.response || [];\nconst fixture = $('Get Fixture2').item.json.response[0];\nconst tickerRaw = $('Get Existing Ticker2').item.json;\nconst ticker = Array.isArray(tickerRaw) ? tickerRaw : [];\nconst body = $('Webhook2').item.json.body;\n\n// Bereits verwendete Icons aus vorhandenen Ticker-Einträgen\nconst usedIcons = new Set(ticker.map(t => t.icon).filter(Boolean));\n\n// Aktuelles Spielresultat\nconst homeGoals = fixture.goals?.home ?? 0;\nconst awayGoals = fixture.goals?.away ?? 0;\nconst minute = fixture.fixture?.status?.elapsed ?? null;\nconst homeName = fixture.teams?.home?.name || body.instance;\nconst awayName = fixture.teams?.away?.name || 'Gegner';\n\n// Statistiken als Key→Value-Map (home team = erster Eintrag)\nconst homeTeamId = fixture.teams?.home?.id;\nconst statMap = {};\nfor (const team of stats) {\n  const side = team.team?.id === homeTeamId ? 'home' : 'away';\n  for (const s of (team.statistics || [])) {\n    statMap[s.type] = statMap[s.type] || {};\n    statMap[s.type][side] = s.value;\n  }\n}\n\n// Fakten aufbauen — nur die, deren Icon noch nicht im Ticker sind\nconst STAT_ICONS = {\n  'Ball Possession':  '⚽ Ballbesitz',\n  'Total Shots':      '🎯 Torschüsse',\n  'Shots on Goal':    '🥅 Aufs Tor',\n  'Corner Kicks':     '🚩 Ecken',\n  'Fouls':            '🟨 Fouls',\n  'Yellow Cards':     '🟨 Gelbe Karten',\n  'Red Cards':        '🟥 Rote Karten',\n  'Passes %':         '📊 Pass-Genauigkeit',\n  'Offsides':         '🚫 Abseits',\n};\n\nconst facts = [];\nfor (const [apiKey, label] of Object.entries(STAT_ICONS)) {\n  if (statMap[apiKey] && !usedIcons.has(label)) {\n    const h = statMap[apiKey].home;\n    const a = statMap[apiKey].away;\n    if (h !== null && h !== undefined && a !== null && a !== undefined) {\n      facts.push(`${label}: ${h} – ${a}`);\n    }\n  }\n}\n\nconst scoreStr = `${homeName} ${homeGoals}:${awayGoals} ${awayName}`;\n\nreturn [{\n  json: {\n    hasFacts: facts.length > 0,\n    facts,\n    scoreStr,\n    minute,\n    homeName,\n    awayName,\n    match_id: body.match_id,\n    instance: body.instance || 'generic',\n    language: body.language || 'de',\n    auto_publish: body.auto_publish ?? false,\n  }\n}];"
      },
      "id": "4aca5cf6-9999-492a-9ced-577f124dd287",
