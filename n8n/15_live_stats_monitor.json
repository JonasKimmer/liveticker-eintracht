    {
      "parameters": {
        "jsCode": "const llmText = $('Generate Text1').item.json.choices?.[0]?.message?.content?.trim() || '';\nconst facts = $('Analyze Facts2').item.json;\n\nif (!llmText) throw new Error('LLM returned empty text');\n\nreturn [{\n  json: {\n    match_id: facts.match_id,\n    text: llmText,\n    minute: facts.minute,\n    status: facts.auto_publish ? 'published' : 'draft',\n    icon: '📊',\n  }\n}];"
      },
