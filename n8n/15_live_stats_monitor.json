        "jsonBody": "={\n  \"model\": \"google/gemini-2.0-flash-001\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Du bist ein Fußball-Live-Ticker-Redakteur. Schreibe einen knappen, lebendigen Statistik-Update auf {{ $json.language }}. Maximal 2-3 Sätze. Kein Hashtag, keine Überschrift.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Spielstand: {{ $json.scoreStr }}\\nMinute: {{ $json.minute }}'\\n\\nStatistiken:\\n{{ $json.facts.join('\\\\n') }}\\n\\nSchreibe jetzt den Ticker-Eintrag.\"\n    }\n  ],\n  \"max_tokens\": 200,\n  \"temperature\": 0.7\n}\n",
