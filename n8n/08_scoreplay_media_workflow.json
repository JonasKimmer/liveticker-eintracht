    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst mediaList = Array.isArray(raw) ? raw : (raw.media || raw.data || []);\n\nconst result = [];\n\nfor (const media of mediaList) {\n  const files = media.files || [];\n  let thumbnail_url = null, compressed_url = null, original_url = null;\n\n  for (const file of files) {\n    const url = file.url || null;\n    if (!url) continue;\n    if (file.is_thumbnail === true) thumbnail_url = url;\n    else if (file.is_compressed === true) compressed_url = url;\n    else if (file.details === 'photographer_quality') original_url = url;\n  }\n\n  thumbnail_url = thumbnail_url || media.thumbnail_url || null;\n  compressed_url = compressed_url || media.compressed_url || null;\n  original_url = original_url || media.original_url || null;\n\n  result.push({ json: {\n    media_id: media.ID,\n    name: media.name || null,\n    thumbnail_url,\n    compressed_url,\n    original_url,\n    event_id: media.event_id || null\n  }});\n}\n\nreturn result;"
      },
