    {
      "parameters": {
        "jsCode": "const body = $('Webhook Trigger5').first().json.body || {};\nconst raw = $input.first().json;\n\nconst players = Array.isArray(raw)\n  ? raw.flatMap(r => r.players || [])\n  : (raw.players || []);\n\nfunction normalize(str) {\n  return (str || '')\n    .toLowerCase()\n    .replace(/ø/g, 'o')\n    .replace(/ö/g, 'o')\n    .replace(/ü/g, 'u')\n    .replace(/ä/g, 'a')\n    .replace(/æ/g, 'ae')\n    .replace(/å/g, 'a')\n    .replace(/ß/g, 'ss')\n    .replace(/đ/g, 'd')\n    .replace(/[''`]/g, '')\n    .normalize('NFD')\n    .replace(/[\\u0300-\\u036f]/g, '');\n}\n\nconst searchBody = {\n  media_type: \"photo\",\n  order_by: \"created_at\",\n  order_type: \"desc\",\n  validated_accessible: true\n};\n\nif (body.player_name) {\n  const nameLower = normalize(body.player_name);\n  const match = players.find(p =>\n    normalize(p.full_name).includes(nameLower) ||\n    normalize(p.first_name).includes(nameLower) ||\n    normalize(p.last_name).includes(nameLower) ||\n    normalize(p.ai_name).includes(nameLower) ||\n    nameLower.includes(normalize(p.last_name))\n  );\n  if (match?.ID) searchBody.players = [match.ID];\n}\n\nreturn [{ json: { searchBody } }];"
      },
