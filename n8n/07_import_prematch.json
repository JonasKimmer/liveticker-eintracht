    {
      "parameters": {
        "jsCode": "const items = $input.first().json.response;\nconst fixtureId = $('Webhook import-prematch').first().json.body.fixture_id;\n\nconst grouped = {};\nfor (const entry of items) {\n  const teamId = entry.team.id;\n  if (!grouped[teamId]) grouped[teamId] = { team_id: teamId, team_name: entry.team.name, players: [] };\n  grouped[teamId].players.push({ player_id: entry.player.id, player_name: entry.player.name, type: entry.player.type, reason: entry.player.reason });\n}\n\nreturn Object.values(grouped).map(team => ({ json: { fixture_id: fixtureId, ...team } }));"
      },
      "id": "ef82d9e6-6010-4ff4-97c1-17a4762c8f25",
      "name": "Injuries extrahieren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1008, -544]
    },
    {
      "parameters": {
        "jsCode": "const fixtures = $input.first().json.response;\nconst fixtureId = $('Webhook import-prematch').first().json.body.fixture_id;\n\nconst last5 = fixtures\n  .filter(f => f.fixture.status.short === 'FT')\n  .sort((a, b) => new Date(b.fixture.date) - new Date(a.fixture.date))\n  .slice(0, 5);\n\nreturn [{ json: { fixture_id: fixtureId, matches: last5.map(f => ({\n  fixture_id: f.fixture.id, date: f.fixture.date,\n  home_team: f.teams.home.name, home_team_id: f.teams.home.id,\n  away_team: f.teams.away.name, away_team_id: f.teams.away.id,\n  goals_home: f.goals.home, goals_away: f.goals.away,\n  winner: f.teams.home.winner ? f.teams.home.name : f.teams.away.winner ? f.teams.away.name : 'draw'\n})) } }];"
      },
      "id": "a377dcb3-9518-410d-9a28-f64f735f8a3c",
      "name": "H2H extrahieren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1008, -336]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json.response;\nconst fixtureId = $('Webhook import-prematch').first().json.body.fixture_id;\nreturn [{ json: { fixture_id: fixtureId, team_id: data.team.id, team_name: data.team.name, league_id: data.league.id, season: data.league.season, form: data.form, played_home: data.fixtures.played.home, played_away: data.fixtures.played.away, wins_total: data.fixtures.wins.total, draws_total: data.fixtures.draws.total, loses_total: data.fixtures.loses.total, goals_for_avg: data.goals.for.average.total, goals_against_avg: data.goals.against.average.total, clean_sheets: data.clean_sheet.total, failed_to_score: data.failed_to_score.total, biggest_win_streak: data.biggest.streak.wins, most_used_formation: data.lineups[0]?.formation ?? null, penalty_scored: data.penalty.scored.total, penalty_missed: data.penalty.missed.total } }];"
      },
