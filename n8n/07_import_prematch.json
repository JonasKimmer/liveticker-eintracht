    {
      "parameters": {
        "jsCode": "const data = $input.first().json.response[0].league;\nconst standings = data.standings[0];\nconst matchData = $('SQL: Match-Daten laden').first().json;\nconst homeId = parseInt(matchData.home_team_external_id);\nconst awayId = parseInt(matchData.away_team_external_id);\n\nreturn [{ json: { fixture_id: matchData.fixture_id, league_id: data.id, league_name: data.name, season: data.season, standings: standings.filter(t => t.team.id === homeId || t.team.id === awayId).map(t => ({ rank: t.rank, team_id: t.team.id, team_name: t.team.name, points: t.points, played: t.all.played, wins: t.all.win, draws: t.all.draw, losses: t.all.lose, goals_for: t.all.goals.for, goals_against: t.all.goals.against, form: t.form })) } }];"
      },
      "id": "9ad9ac3e-fce3-44ed-95c2-36eadf2a9d5e",
      "name": "Standings extrahieren",
