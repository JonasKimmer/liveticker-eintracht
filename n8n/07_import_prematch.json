    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH ins AS (\n  INSERT INTO synthetic_events (match_id, type, data)\n  VALUES ((SELECT id FROM matches WHERE external_id = $1), $2, $3::jsonb)\n  ON CONFLICT (match_id, type) DO UPDATE SET data = EXCLUDED.data\n  RETURNING id\n)\nSELECT ins.id FROM ins\nLEFT JOIN ticker_entries te ON te.synthetic_event_id = ins.id AND te.status != 'rejected'\nWHERE te.id IS NULL\n",
        "options": {
          "queryReplacement": "={{ [$json.fixture_id, 'pre_match_injuries_' + $json.team_id, JSON.stringify($json)] }}"
        }
