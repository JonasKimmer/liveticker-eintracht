# ── Datenbank (Supabase) ──────────────────────────────────────────
# Supabase → Project Settings → Database → Connection String (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── Server ────────────────────────────────────────────────────────
DEBUG=false
PUBLIC_BASE_URL=https://liveticker-backend.onrender.com
CORS_ORIGINS=["https://liveticker-frontend.onrender.com"]

# ── LLM API Keys (mindestens einer) ──────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-...

# ── Sport-Daten API ───────────────────────────────────────────────
API_FOOTBALL_KEY=...

# ── n8n Webhooks (Railway-URL) ────────────────────────────────────
N8N_WEBHOOK_LINEUP=https://deine-n8n.railway.app/webhook/lineups
N8N_WEBHOOK_EVENTS=https://deine-n8n.railway.app/webhook/Events
N8N_WEBHOOK_STATISTICS=https://deine-n8n.railway.app/webhook/statistics
N8N_WEBHOOK_PLAYER_STATISTICS=https://deine-n8n.railway.app/webhook/Player-Statistics
N8N_WEBHOOK_PREMATCH=https://deine-n8n.railway.app/webhook/import-prematch
N8N_WEBHOOK_COMPETITIONS=https://deine-n8n.railway.app/webhook/import-team-competitions
N8N_WEBHOOK_MATCHES=https://deine-n8n.railway.app/webhook/import-matches
N8N_WEBHOOK_COUNTRY=https://deine-n8n.railway.app/webhook/import-country
