    {
      "parameters": {
        "jsCode": "return [\n  { json: { league_id: 78,  team_id: 169, season: 2025, shortTitle: \"BL\" } },\n  { json: { league_id: 81,  team_id: 169, season: 2025, shortTitle: \"DFB\" } },\n  { json: { league_id: 2,   team_id: 169, season: 2025, shortTitle: \"CL\" } },\n  { json: { league_id: 667, team_id: 169, season: 2025, shortTitle: \"FR\" } },\n];"
