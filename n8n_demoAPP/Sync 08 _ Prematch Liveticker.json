    {
      "parameters": {
        "jsCode": "const c = $('Konfiguration').first().json;\nconst pred = $('GET: Predictions').first().json.response?.[0];\nconst injuries = $('GET: Injuries').first().json.response || [];\nconst h2h = $('GET: H2H').first().json.response || [];\n\nconst last5h2h = h2h\n  .filter(f => f.fixture.status.short === 'FT')\n  .sort((a, b) => new Date(b.fixture.date) - new Date(a.fixture.date))\n  .slice(0, 5)\n  .map(f => `${f.teams.home.name} ${f.goals.home}:${f.goals.away} ${f.teams.away.name}`);\n\nconst injuryList = injuries.map(i => `${i.player.name} (${i.team.name}): ${i.player.reason}`).join(', ') || 'Keine bekannten Verletzungen';\n\nconst predText = pred ? `Tipp: ${pred.predictions?.winner?.name ?? 'Unentschieden'} - ${pred.predictions?.advice ?? ''}` : '';\n\nreturn [\n  {\n    json: {\n      sourceId: `${c.fixture_id}-prediction`,\n      prompt: `Du bist Liveticker-Redakteur für Eintracht Frankfurt. Schreibe einen spannenden Pre-Match Ticker-Eintrag (max. 3 Sätze, Deutsch, Eintracht-Stil) zur Spielvorschau:\\n\\n${predText}\\n\\nNur den Text ausgeben.`,\n      matchId: c.match_id,\n      eventType: 'Default'\n    }\n  },\n  {\n    json: {\n      sourceId: `${c.fixture_id}-h2h`,\n      prompt: `Du bist Liveticker-Redakteur für Eintracht Frankfurt. Schreibe einen Pre-Match Ticker-Eintrag (max. 3 Sätze, Deutsch, Eintracht-Stil) zum Head-to-Head:\\n\\nLetzte 5 Duelle:\\n${last5h2h.join('\\n')}\\n\\nNur den Text ausgeben.`,\n      matchId: c.match_id,\n      eventType: 'Default'\n    }\n  },\n  {\n    json: {\n      sourceId: `${c.fixture_id}-injuries`,\n      prompt: `Du bist Liveticker-Redakteur für Eintracht Frankfurt. Schreibe einen Pre-Match Ticker-Eintrag (max. 2 Sätze, Deutsch, Eintracht-Stil) zu den Verletzungen:\\n\\n${injuryList}\\n\\nNur den Text ausgeben.`,\n      matchId: c.match_id,\n      eventType: 'Default'\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        800,
        -48
      ],
      "id": "1859ba97-8ba9-406c-9a7d-01059869a3cd",
      "name": "Pre-Match Prompts bauen"
    },
    {
