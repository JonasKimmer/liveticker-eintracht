      ],
      "id": "3a9bca91-d1c9-47d7-8f8d-1674183d208e",
      "name": "GET: Already posted Events"
    },
    {
      "parameters": {
        "jsCode": "const allPostedIds = new Set(\n  $('GET: Already posted Events').all()\n    .flatMap(item => (item.json.items || []).map(e => e.sourceId))\n);\n\nconst prompts = $('Pre-Match Prompts bauen').all();\n\nreturn prompts\n  .filter(p => !allPostedIds.has(p.json.sourceId))\n  .map(p => ({ json: p.json }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        -48
      ],
      "id": "ccd7ee40-5e8e-49ca-ad3a-68fb86c26915",
