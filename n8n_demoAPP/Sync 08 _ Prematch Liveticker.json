    {
      "parameters": {
        "jsCode": "const llm = $input.first().json;\nconst evData = $('Filter: Noch nicht gepostet').all()[$itemIndex]?.json || {};\nconst text = llm.choices?.[0]?.message?.content || null;\n\nreturn [{\n  json: {\n    matchId: evData.matchId,\n    body: {\n      sourceId:            evData.sourceId,\n      sport:               'Football',\n      position:            0,\n      time:                null,\n      timeAdditional:      null,\n      description:         text,\n      imageUrl:            null,\n      videoUrl:            null,\n      pushTitle:           null,\n      pushDescription:     null,\n      pushImageSrc:        null,\n      embedHtml:           null,\n      liveTickerPhaseType: 'Before',\n      liveTickerEventType: evData.eventType,\n      players:             []\n    }\n  }\n}];"
      },
