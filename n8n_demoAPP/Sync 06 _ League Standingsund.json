    {
      "parameters": {
        "jsCode": "const item = $input.all()[0];\nconst standings = item.json.response[0].league.standings[0];\nconst competition_id = $('Liga Liste').all()[$itemIndex].json.competition_id;\nconst season_id = $('Liga Liste').all()[$itemIndex].json.season_id;\nconst matchday = $('Liga Liste').all()[$itemIndex].json.matchday;\n\nreturn [{\n  json: {\n    season_id,\n    competition_id,\n    matchday,\n    standings: standings.map(s => ({\n      teamId: s.team.id,\n      sport: \"Football\",\n      position: s.rank,\n      trend: null,\n      matchesPlayed: s.all.played,\n      matchesWon: s.all.win,\n      matchesDrawn: s.all.draw,\n      matchesLost: s.all.lose,\n      goalsFor: s.all.goals.for,\n      goalsAgainst: s.all.goals.against,\n      goalBalance: s.goalsDiff,\n      points: s.points\n    }))\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
