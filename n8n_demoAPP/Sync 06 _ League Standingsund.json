        "jsCode": "const c = $('Konfiguration').first().json;\nreturn [\n  { json: { league_id: c.league_bundesliga, competition_id: c.comp_bundesliga, matchday: c.matchday_bl, season: c.season, season_id: c.season_id } },\n  { json: { league_id: c.league_cl,         competition_id: c.comp_cl,         matchday: c.matchday_cl, season: c.season, season_id: c.season_id } }\n];"
